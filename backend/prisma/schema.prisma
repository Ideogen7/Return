// =============================================================================
// Return API — Prisma Schema
// =============================================================================

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// AUTH & USERS
// =============================================================================

/// Rôle utilisateur (V1 : rôle unique LENDER)
enum UserRole {
  LENDER
}

/// Utilisateur inscrit pouvant prêter et/ou emprunter
model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  password  String // Hashed via bcrypt (12 rounds)
  firstName String   @map("first_name") @db.VarChar(50)
  lastName  String   @map("last_name") @db.VarChar(50)
  role      UserRole @default(LENDER)

  // Profil optionnel
  profilePicture String? @map("profile_picture")
  phone          String? @db.VarChar(20)

  // Préférences (embarquées dans la même table pour simplifier le MVP)
  pushNotificationsEnabled Boolean @default(true) @map("push_notifications_enabled")
  reminderEnabled          Boolean @default(true) @map("reminder_enabled")
  language                 String  @default("fr") @db.VarChar(5)
  timezone                 String  @default("Europe/Paris") @db.VarChar(50)

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")

  // Relations
  refreshTokens   RefreshToken[]
  borrowerProfile Borrower[]     @relation("BorrowerUser") // Contacts linked to this user as borrower
  borrowers       Borrower[]     @relation("LenderBorrowers") // Contacts this user owns as lender
  items           Item[]
  loans           Loan[]         @relation("LenderLoans") // Loans this user created as lender

  // Contact Invitations
  sentInvitations     ContactInvitation[] @relation("SentInvitations")
  receivedInvitations ContactInvitation[] @relation("ReceivedInvitations")

  // Notifications & Device Tokens (Sprint 5)
  notifications Notification[]
  deviceTokens  DeviceToken[]

  @@map("users")
}

/// Token de rafraîchissement JWT (1-N avec User)
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique // Hashed refresh token
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================================================
// BORROWERS (Contacts / Emprunteurs)
// =============================================================================

/// Emprunteur — contact du carnet d'adresses d'un prêteur
model Borrower {
  id          String  @id @default(uuid()) @db.Uuid
  firstName   String  @map("first_name") @db.VarChar(50)
  lastName    String  @map("last_name") @db.VarChar(50)
  email       String
  phoneNumber String? @map("phone_number")

  /// ID utilisateur Return (null si invitation en attente)
  userId String? @map("user_id") @db.Uuid

  /// Prêteur propriétaire de ce contact
  lenderUserId String @map("lender_user_id") @db.Uuid

  // Statistiques dénormalisées (mises à jour via événements lors des changements de statut de prêt)
  trustScore         Float @default(0) @map("trust_score")
  totalLoans         Int   @default(0) @map("total_loans")
  returnedOnTime     Int   @default(0) @map("returned_on_time")
  returnedLate       Int   @default(0) @map("returned_late")
  notReturned        Int   @default(0) @map("not_returned")
  averageReturnDelay Int?  @map("average_return_delay")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user       User?  @relation("BorrowerUser", fields: [userId], references: [id], onDelete: SetNull)
  lenderUser User   @relation("LenderBorrowers", fields: [lenderUserId], references: [id], onDelete: Cascade)
  loans      Loan[]

  // Un prêteur ne peut pas avoir deux contacts avec le même email
  @@unique([lenderUserId, email])
  @@index([lenderUserId])
  @@index([userId])
  @@map("borrowers")
}

// =============================================================================
// ITEMS (Objets prêtés)
// =============================================================================

/// Catégorie d'objet sélectionnée par le prêteur
/// MONEY active le workflow prêt d'argent (estimatedValue = montant prêté, obligatoire)
enum ItemCategory {
  TOOLS
  BOOKS
  ELECTRONICS
  SPORTS
  KITCHEN
  GARDEN
  MONEY
  OTHER
}

/// Bien physique ou somme d'argent faisant l'objet d'un Prêt
model Item {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(100)
  description    String?      @db.VarChar(500)
  category       ItemCategory
  estimatedValue Float?       @map("estimated_value")

  // Propriétaire (prêteur)
  userId String @map("user_id") @db.Uuid

  // Soft delete
  deletedAt DateTime? @map("deleted_at")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos Photo[]
  loans  Loan[]

  @@index([userId])
  @@index([category])
  @@map("items")
}

// =============================================================================
// PHOTOS (Images d'objets sur Cloudflare R2)
// =============================================================================

/// Photo d'un objet stockée sur Cloudflare R2 (ou disque local en dev)
model Photo {
  id           String  @id @default(uuid()) @db.Uuid
  url          String
  thumbnailUrl String? @map("thumbnail_url")

  // Objet parent
  itemId String @map("item_id") @db.Uuid

  // Timestamps
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  // Relations
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("photos")
}

// =============================================================================
// LOANS (Prêts — cœur métier)
// =============================================================================

/// Statut du cycle de vie d'un prêt (8 statuts)
enum LoanStatus {
  PENDING_CONFIRMATION
  ACTIVE
  ACTIVE_BY_DEFAULT
  CONTESTED
  AWAITING_RETURN
  RETURNED
  NOT_RETURNED
  ABANDONED
}

/// Prêt d'un objet ou d'argent entre un prêteur et un emprunteur
model Loan {
  id String @id @default(uuid()) @db.Uuid

  // Relations FK
  itemId     String @map("item_id") @db.Uuid
  lenderId   String @map("lender_id") @db.Uuid
  borrowerId String @map("borrower_id") @db.Uuid

  // Cycle de vie
  status           LoanStatus @default(PENDING_CONFIRMATION)
  returnDate       DateTime?  @map("return_date") @db.Date
  confirmationDate DateTime?  @map("confirmation_date")
  returnedDate     DateTime?  @map("returned_date")
  contestReason    String?    @map("contest_reason") @db.VarChar(500)
  notes            String?    @db.VarChar(500)

  // Soft delete
  deletedAt DateTime? @map("deleted_at")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  item     Item     @relation(fields: [itemId], references: [id])
  lender   User     @relation("LenderLoans", fields: [lenderId], references: [id])
  borrower Borrower @relation(fields: [borrowerId], references: [id])

  // Reminders & Notifications (Sprint 5)
  reminders     Reminder[]
  notifications Notification[]

  @@index([lenderId, status])
  @@index([borrowerId])
  @@index([itemId])
  @@map("loans")
}

// =============================================================================
// CONTACT INVITATIONS (Système d'invitation de contacts avec consentement)
// =============================================================================

/// Statut du cycle de vie d'une invitation de contact
/// PENDING → ACCEPTED | REJECTED | EXPIRED (après 30 jours sans réponse)
enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

/// Invitation de contact entre deux utilisateurs inscrits
/// Le destinataire doit être inscrit (recipientUserId NOT NULL)
///
/// Index unique partiel : un seul PENDING par (sender, recipientEmail)
/// → ajouté via raw SQL dans la migration (Prisma ne supporte pas les partial indexes)
model ContactInvitation {
  id              String           @id @default(uuid()) @db.Uuid
  senderUserId    String           @map("sender_user_id") @db.Uuid
  recipientEmail  String           @map("recipient_email")
  recipientUserId String           @map("recipient_user_id") @db.Uuid
  status          InvitationStatus @default(PENDING)

  // Timestamps
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")
  rejectedAt DateTime? @map("rejected_at")

  // Relations
  senderUser    User @relation("SentInvitations", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipientUser User @relation("ReceivedInvitations", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([senderUserId])
  @@index([recipientUserId])
  @@index([status])
  @@map("contact_invitations")
}

// =============================================================================
// REMINDERS (Rappels automatiques — politique fixe)
// =============================================================================

/// Type de rappel (politique fixe, 5 rappels automatiques)
enum ReminderType {
  PREVENTIVE       // J-3 si Δ ≥ 3 jours, sinon J-1
  ON_DUE_DATE      // Le jour de la date de retour (J)
  FIRST_OVERDUE    // J+7
  SECOND_OVERDUE   // J+14
  FINAL_OVERDUE    // J+21, dernier rappel avant NOT_RETURNED
}

/// Statut du cycle de vie d'un rappel
enum ReminderStatus {
  SCHEDULED  // Planifié, non encore envoyé
  SENT       // Envoyé avec succès
  FAILED     // Échec d'envoi (retry prévu)
  CANCELLED  // Annulé (prêt rendu avant l'envoi)
}

/// Canal de notification (V1 : push uniquement)
enum NotificationChannel {
  PUSH
}

/// Rappel automatique envoyé à l'emprunteur via push notification
model Reminder {
  id           String              @id @default(uuid()) @db.Uuid
  loanId       String              @map("loan_id") @db.Uuid
  type         ReminderType
  status       ReminderStatus      @default(SCHEDULED)
  scheduledFor DateTime            @map("scheduled_for")
  sentAt       DateTime?           @map("sent_at")
  message      String?
  channel      NotificationChannel @default(PUSH)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, status])
  @@index([status, scheduledFor])
  @@map("reminders")
}

// =============================================================================
// NOTIFICATIONS (Notifications push — FCM)
// =============================================================================

/// Type de notification push
enum NotificationType {
  LOAN_CREATED
  LOAN_CONFIRMED
  LOAN_AUTO_CONFIRMED
  LOAN_CONTESTED
  LOAN_RETURNED
  REMINDER_SENT
  REMINDER_RECEIVED
}

/// Notification push reçue par l'utilisateur
model Notification {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  type          NotificationType
  title         String
  body          String
  isRead        Boolean          @default(false) @map("is_read")
  relatedLoanId String?          @map("related_loan_id") @db.Uuid

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedLoan Loan? @relation(fields: [relatedLoanId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// =============================================================================
// DEVICE TOKENS (Tokens FCM pour notifications push)
// =============================================================================

/// Plateforme du device mobile
enum DevicePlatform {
  ios
  android
  web
}

/// Token FCM d'un device utilisateur pour recevoir les notifications push
model DeviceToken {
  id       String         @id @default(uuid()) @db.Uuid
  userId   String         @map("user_id") @db.Uuid
  token    String
  platform DevicePlatform

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Un token FCM est unique globalement
  @@unique([token])
  @@index([userId])
  @@map("device_tokens")
}
